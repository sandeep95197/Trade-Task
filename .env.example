# Copy this file to .env before running the server:
#   cp .env.example .env

# Get a free key at https://aistudio.google.com
# Leave empty to use the built-in template report instead.
GEMINI_API_KEY=your_google_gemini_api_key_here

# Change this to a long random string before deploying anywhere public.
# Quick way to generate one: openssl rand -hex 32
JWT_SECRET=your_strong_random_secret_here
